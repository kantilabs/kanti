{
	"name": "kanti",
	"productName": "kanti",
	"version": "0.2.1",
	"description": "A web appication tool for modifying http requests",
	"main": ".vite/main/main.js",
	"type": "module",
	"scripts": {
		"start": "electron-forge start",
		"package": "npm run build:go && electron-forge package",
		"make": "npm run build:go && electron-forge make",
		"publish": "npm run build:go && electron-forge publish",
		"build:go": "cd src-go && go build -o bin/kanti-backend ./cmd/kproxy-backend",
		"build:go:windows": "cd src-go && go build -o bin/kanti-backend.exe ./cmd/kproxy-backend",
		"svelte-dev": "vite -c ./vite.renderer.config.ts",
		"svelte-build": "vite build -c ./vite.renderer.config.ts",
		"svelte-check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"svelte-check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest"
	},
	"devDependencies": {
		"@electron-forge/cli": "7",
		"@electron-forge/maker-deb": "7",
		"@electron-forge/maker-rpm": "7",
		"@electron-forge/maker-squirrel": "7",
		"@electron-forge/maker-zip": "7",
		"@electron-forge/plugin-auto-unpack-natives": "7",
		"@electron-forge/plugin-fuses": "7",
		"@electron-forge/plugin-vite": "^7.11.2",
		"@electron-forge/publisher-github": "^7.11.2",
		"@electron/fuses": "1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "2",
		"@sveltejs/vite-plugin-svelte": "7",
		"@tailwindcss/vite": "4",
		"@types/electron-squirrel-startup": "1",
		"@types/http-proxy": "^1.17.17",
		"@types/node": "^26.1.1",
		"@types/node-forge": "^1.3.14",
		"electron": "43",
		"globals": "17",
		"svelte": "5",
		"svelte-check": "4",
		"tailwindcss": "4",
		"tsx": "4",
		"typescript": "6",
		"vite": "8",
		"vitest": "4"
	},
	"keywords": [],
	"author": {
		"name": "oyasumi",
		"email": "oyasumi@hackerforhire.xyz"
	},
	"license": "MIT",
	"dependencies": {
		"@codemirror/theme-one-dark": "^6.1.3",
		"@types/d3": "^7.4.3",
		"compress-brotli": "^1.3.14",
		"d3": "^7.9.0",
		"electron-squirrel-startup": "^1.0.1",
		"electron-store": "^11.0.2",
		"highlight.js": "^11.11.1",
		"http-proxy": "^1.18.1",
		"iconv-lite": "^0.7.3",
		"lru-cache": "^11.5.2",
		"marked": "^18.0.6",
		"node-forge": "^1.4.0",
		"svelte-codemirror-editor": "^2.1.0",
		"svelte-splitpanes": "^8.0.12",
		"uuid": "^14.0.1"
	},
	"overrides": {
		"tar": "^7.5.16",
		"tmp": "^0.2.7",
		"cookie": "^0.7.2"
	}
}
